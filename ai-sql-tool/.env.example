# ─────────────────────────────────────────────
#  AI Data Analyst – Environment Configuration
# ─────────────────────────────────────────────

# Groq API
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# PostgreSQL Connection (NeonDB or other providers)
DATABASE_URL=postgresql://user:password@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# Or use individual variables (fallback if DATABASE_URL is not provided)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=analytics_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# App Settings
APP_TITLE=AI Data Analyst
MAX_QUERY_RETRIES=2
QUERY_CACHE_TTL=300          # seconds
MAX_ROWS_DISPLAY=1000
ENABLE_AUTH=false

# Basic Auth (only used if ENABLE_AUTH=true)
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme123
